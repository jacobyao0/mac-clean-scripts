#!/bin/zsh
# kimi-clean - 精简版：只处理需要交互/精细控制的 Kimi 会话
# 其他功能已移至 auto-clean-safe：
#   - Homebrew/uv/Python/VS Code旧版本缓存
#   - VS Code 插件版本清理
#   - Kimi 空会话/空文件/临时图片/App缓存

# 注意：不在全局启用 nullglob，避免影响 ls 等命令
# 使用 (N) glob 修饰符局部处理空目录

echo "=== Kimi CLI 状态 ==="

# 1. 日志（自动清理，仅报告）
LOG_COUNT=$(find ~/.kimi/logs -maxdepth 1 -name "*.log" -type f 2>/dev/null | wc -l)
LOG_SIZE=$(du -sh ~/.kimi/logs 2>/dev/null | cut -f1)
echo "📋 日志：$LOG_COUNT 个文件，$LOG_SIZE（自动保留10天）"

# 2. 有效会话（选择性删除）
SESSION_DIR="$HOME/.kimi/sessions"

# 只统计有内容的会话
VALID_SESSIONS=0
if [[ -d "$SESSION_DIR" ]]; then
    for workdir in "$SESSION_DIR"/*(/N); do
        for subsession in "$workdir"/*(/N); do
            ctx_file="$subsession/context.jsonl"
            wire_file="$subsession/wire.jsonl"
            
            # 检查是否有实际内容（非空文件）
            if [[ -f "$ctx_file" ]] && [[ -s "$ctx_file" ]] && [[ -f "$wire_file" ]]; then
                ((VALID_SESSIONS++))
            fi
        done
    done
fi

echo "💬 有效会话：$VALID_SESSIONS 个（空白会话已由 auto-clean-safe 自动清理）"

# 定义获取标题的函数
get_session_title() {
    local wire_file="$1"
    if [[ -f "$wire_file" ]]; then
        local title=$(grep -m1 '"type": "TurnBegin"' "$wire_file" 2>/dev/null | python3 "$HOME/.local/bin/kimi_clean_helper.py" 2>/dev/null)
        if [[ -n "$title" ]]; then
            echo "$title"
            return
        fi
    fi
    echo ""
}

# 交互式删除有效会话
if [[ "$VALID_SESSIONS" -gt 0 ]]; then
    echo ""
    echo "有效会话列表（输入编号删除，直接回车跳过）："
    echo ""
    
    SESSIONS=()
    IDX=0
    
    for workdir in "$SESSION_DIR"/*(om/); do
        [[ -d "$workdir" ]] || continue
        
        workdir_short="${workdir:t}"
        [[ ${#workdir_short} -gt 12 ]] && workdir_short="${workdir_short:0:12}..."
        
        for subsession in "$workdir"/*(om/); do
            [[ -d "$subsession" ]] || continue
            
            wire_file="$subsession/wire.jsonl"
            context_file="$subsession/context.jsonl"
            
            # 只显示有效会话（有内容的）
            if [[ ! -f "$wire_file" ]] || [[ ! -f "$context_file" ]] || [[ ! -s "$context_file" ]]; then
                continue
            fi
            
            ((IDX++))
            
            title=$(get_session_title "$wire_file")
            [[ -z "$title" ]] && title="(无标题)"
            
            size_h=$(ls -lh "$context_file" 2>/dev/null | awk '{print $5}')
            mtime=$(stat -f "%Sm" -t "%m-%d %H:%M" "$context_file" 2>/dev/null)
            
            printf "  [%2d] %-40s │ %s │ %s │ %s\n" "$IDX" "$title" "$workdir_short" "$size_h" "$mtime"
            
            SESSIONS+=("$subsession")
        done
    done
    
    if [[ "$IDX" -gt 0 ]]; then
        echo ""
        echo "输入要删除的编号（如: 1,2,3 或 all），回车跳过:"
        read -r SELECTION
        
        if [[ -n "$SELECTION" ]]; then
            if [[ "$SELECTION" == "all" ]]; then
                echo "确定删除所有有效会话? (y/N):"
                read -r CONFIRM
                if [[ "$CONFIRM" == "y" ]] || [[ "$CONFIRM" == "Y" ]]; then
                    rm -rf "$SESSION_DIR"/*
                    echo "✅ 已删除所有会话"
                fi
            else
                IFS=',' read -rA NUMS <<< "$SELECTION"
                DELETED=0
                for num in "${NUMS[@]}"; do
                    num=$(echo "$num" | tr -d ' ')
                    if [[ "$num" =~ ^[0-9]+$ ]] && [[ "$num" -ge 1 ]] && [[ "$num" -le "${#SESSIONS[@]}" ]]; then
                        target="${SESSIONS[$num]}"
                        wire="$target/wire.jsonl"
                        title=$(get_session_title "$wire")
                        [[ -z "$title" ]] && title="(无标题)"
                        echo "删除 [$num]: ${title:0:30}..."
                        rm -rf "$target"
                        ((DELETED++))
                        
                        parent="${target:h}"
                        [[ -z "$(ls -A "$parent" 2>/dev/null)" ]] && rmdir "$parent" 2>/dev/null
                    fi
                done
                [[ "$DELETED" -gt 0 ]] && echo "✅ 已删除 $DELETED 个会话"
            fi
        fi
    fi
else
    echo "没有有效会话需要清理"
fi

echo ""
echo "✅ 完成 $(date '+%H:%M')"

